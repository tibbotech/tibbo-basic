include "global.tbh"

dim aa as string

sub finalthing(input as string)
    sys.debugprint(input)
end sub

sub somethingelse(input as string)
    finalthing(input)
end sub

sub dosomething(input as string)
    somethingelse(input)
end sub

sub on_sys_init()
	aa = "hello"
    dim bb as byte
    bb = 3
	dosomething(aa + str(bb) + "asdf")
    bb = bb + 3
    sys.debugprint(str(bb))
    pat.play("B-G-~",PL_PAT_CANINT)
end sub
