include "global.tbh"

dim aa as string
dim asdf as byte=4
dim bbzz as string
dim zzaa as string

dim interface_ready(MAX_NUM_INTERFACES) as no_yes
dim current_interface as pl_sock_interfaces

declare function add(byref a as byte, b as byte) as word


sub finalthing(byref input as string)
    dim zz as byte=1
    sys.debugprint(input)
    zz=add(zz, 3)
    sys.debugprint(str(zz) + "asdf" + str(zz + 3))
end sub

sub somethingelse(input as string)
    finalthing(input)
end sub

sub dosomething(input as string)
    somethingelse(input)
end sub

sub on_sys_init()
    sys.debugprint("hi hello world")
	aa = "hello"
    dim bb as byte
    bb = 3
	somethingelse(aa + str(bb) + "asdf")
    bb = bb + 3
    sys.debugprint(str(bb))
    pat.play("B-G-~",PL_PAT_CANINT)

    boot()
end sub


function add(byref a as byte, b as byte) as word
    sys.debugprint(str(a))
    add = a + b
end function

sub on_button_pressed()
    sys.debugprint("button pressed")
end sub

sub on_sys_timer()
    sys.debugprint("timaaaer")
end sub