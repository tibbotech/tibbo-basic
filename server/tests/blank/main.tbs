include "global.tbh"

dim aa as string

declare function add(a as byte, b as byte) as word


sub finalthing(byref input as string)
    dim zz as byte=1
    sys.debugprint(input)
    zz=add(zz, 3)
    sys.debugprint(str(zz) + "asdf" + str(zz + 3))
end sub

sub somethingelse(input as string)
    finalthing(input)
end sub

sub dosomething(input as string)
    somethingelse(input)
end sub

sub on_sys_init()
	aa = "hello"
    dim bb as byte
    bb = 3
	somethingelse(aa + str(bb) + "asdf")
    bb = bb + 3
    sys.debugprint(str(bb))
    pat.play("B-G-~",PL_PAT_CANINT)
end sub


function add(a as byte, b as byte) as word
    add = a + b
end function