include "global.tbh"

const TEST_STRING = "teststring"

sub dhcp_start(interface as pl_sock_interfaces, byref requested_ip as string)
    sys.debugprint(requested_ip)

    dim target_interface as pl_sock_interfaces = interface
end sub


sub test3(ds as string)
    sys.debugprint(ds)
    dhcp_start(PL_SOCK_INTERFACE_NET, "192.168.1.101")
end sub

function test2() as byte
    test2 = 45
end function

sub test()
    dim a as byte=0
    a = 1
    sys.debugprint(str(a))
end sub

sub on_sys_init()
    dim z as byte = 3 + 4
    sys.debugprint("on_sys_init")
    test()
    dim b as byte=test2()
    b=b+z
    test3(TEST_STRING)
end sub
