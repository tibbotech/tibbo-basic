include "global.tbh"

sub test4(byref s as string)
    s = "asdfasdf"
    dim baa as string = "asdf" + "zzz"
    sys.debugprint(baa)
    dim bzz as string = "aaa" + s
    sys.debugprint(bzz)
end sub

sub test3(byref s as string)
    ' s = "number is "
    sys.debugprint(s)
    test4(s)
end sub

function test2(s as string) as byte
    test2 = 3
    test3(s)
end function

sub test(z as byte)
    sys.debugprint("a: " + str(z))
end sub

sub on_sys_init()
    sys.debugprint("on_sys_init")
    dim aa as byte=2
    test(aa + 1)
    test2("number is " + str(aa))
end sub
