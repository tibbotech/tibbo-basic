include "global.tbh"


dim num_sockets(32) as byte

sub on_sys_init()
    dim i as byte=1
    dim z as byte=0
    for i=0 to 32
        num_sockets(i) = i
    next i
    for i=0 to 32
        z = num_sockets(i)
        sys.debugprint(str(num_sockets(0)))
        dim j as byte = i
        sys.debugprint(str(j))
        dim ss as string = str(z + 1)
        sys.debugprint(ss)
        ' dim zz as string = str(num_sockets(i))
        ' sys.debugprint(zz)
    next i
    i = 3
    z = num_sockets(i)
    sys.debugprint(str(z))
    sys.debugprint("done")
end sub
